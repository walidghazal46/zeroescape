<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <!-- Exclude all shared preferences (contain session state, auth tokens) -->
        <exclude domain="sharedpref" path="." />
        <!-- Exclude databases (local session/stats cache) -->
        <exclude domain="database" path="." />
        <!-- Exclude external files -->
        <exclude domain="external" path="." />
    </cloud-backup>
    <device-transfer>
        <!-- Do not transfer session or auth data between devices -->
        <exclude domain="sharedpref" path="." />
        <exclude domain="database" path="." />
    </device-transfer>
</data-extraction-rules>